# syntax=docker/dockerfile:1
#
# deploy/docker/Dockerfile.release — packages a PREBUILT pylon binary into a
# minimal runtime image. Used by .github/workflows/release.yml, which builds
# native binaries per-arch and stages them under dist/<arch>/pylon, then runs
# a single multi-platform `buildx` build (so no compilation happens here).
#
# For a from-source image instead, use deploy/docker/Dockerfile.
#
# Health probes (for orchestrators / docker run --health-cmd):
#   Liveness:   GET /health  → 200 "ok"
#   Readiness:  GET /ready   → 200 "ready" / 503 "draining"

FROM debian:bookworm-slim

# ca-certificates: outbound TLS (webhook delivery over https, rediss://).
# wget: used by the docker-compose / HEALTHCHECK probe of GET /health
# (debian-slim ships neither curl nor wget).
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates wget && \
    rm -rf /var/lib/apt/lists/*

# Non-root runtime user.
RUN useradd --system --no-create-home --shell /usr/sbin/nologin pylon

# TARGETARCH is set by buildx per target platform (amd64 | arm64); the release
# workflow stages the matching native binary at dist/<arch>/pylon.
ARG TARGETARCH
COPY dist/${TARGETARCH}/pylon /usr/local/bin/pylon
COPY apps.example.json /etc/pylon/apps.example.json

EXPOSE 7000

USER pylon

ENTRYPOINT ["/usr/local/bin/pylon"]
