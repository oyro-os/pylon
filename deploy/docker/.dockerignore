# Build artifacts — largest directory; always exclude.
target/

# Version control
.git/
.gitignore
.gitattributes

# Reference oracles (large; not needed for the build)
reference/

# Documentation
docs/
*.md
!README.md

# Deploy artifacts (not needed inside the image)
deploy/

# CI/CD / tooling configs
.github/
.cargo/config.toml

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Test data / fixtures (if any)
tests/fixtures/

# Scripts (runtime binary only)
scripts/
