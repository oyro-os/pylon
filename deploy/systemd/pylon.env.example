# /etc/pylon/pylon.env — copy this file to /etc/pylon/pylon.env and edit.
# Owned by root:pylon, mode 0640 (the pylon user reads it; others cannot).
#   install -m 0640 -o root -g pylon pylon.env.example /etc/pylon/pylon.env

# ── Listener ─────────────────────────────────────────────────────────────────

# IP address to bind.  0.0.0.0 = all interfaces.
PYLON_BIND=0.0.0.0

# TCP port.
PYLON_PORT=7000

# ── Workers ───────────────────────────────────────────────────────────────────

# Number of I/O worker threads.  0 = auto (one per logical CPU).
PYLON_WORKERS=0

# ── Adapter ───────────────────────────────────────────────────────────────────

# "local" (single-node, no Redis) or "redis" (cluster mode).
PYLON_ADAPTER=local

# Required when PYLON_ADAPTER=redis.
#PYLON_REDIS_URL=redis://127.0.0.1:6379

# Key prefix for pylon Redis channels.
#PYLON_REDIS_PREFIX=pylon

# ── Applications ─────────────────────────────────────────────────────────────

# Path to the apps.json file.  See apps.example.json for format.
PYLON_APPS_PATH=/etc/pylon/apps.json

# ── Capacity / memory ────────────────────────────────────────────────────────

# Soft memory cap in bytes.  When resident memory approaches this value pylon
# starts rejecting new connections (HTTP 4004).  0 = no limit.
# Example: 8 GiB = 8589934592
#PYLON_MEMORY_BUDGET_BYTES=0

# ── Graceful shutdown ─────────────────────────────────────────────────────────

# Milliseconds to wait after SIGTERM before beginning the connection drain.
# During this window /ready returns 503, letting load balancers stop sending
# new connections before existing ones are closed.
PYLON_SHUTDOWN_PREDRAIN_MS=2000

# Maximum milliseconds to wait for in-flight connections to flush before
# forcing process exit.
PYLON_SHUTDOWN_GRACE_MS=10000

# ── Webhooks ─────────────────────────────────────────────────────────────────

#PYLON_WEBHOOK_URL=
#PYLON_WEBHOOK_TIMEOUT_MS=3000
#PYLON_WEBHOOK_RETRY_COUNT=3

# ── CoDel / overload ─────────────────────────────────────────────────────────

# Active queue management (CoDel) target queue delay in milliseconds.
#PYLON_CODEL_TARGET_MS=5
# CoDel interval in milliseconds.
#PYLON_CODEL_INTERVAL_MS=100

# PSI (Pressure Stall Information) thresholds for shedding load.
#PYLON_PSI_CPU_THRESHOLD=0.70
#PYLON_PSI_MEM_THRESHOLD=0.80
